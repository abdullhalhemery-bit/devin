# ═══════════════════════════════════════════════════
#  devin — Environment Variables
#
#  DO NOT commit this file with real values!
#  Copy to .env.local for local development.
#  On Vercel: set these in Dashboard → Settings → Environment Variables
# ═══════════════════════════════════════════════════

# HD Wallet Seed Phrase (12 words) — used to generate unique destination addresses
# Each FID transfer gets a new address derived from this seed
SEED_PHRASE=your_twelve_word_seed_phrase_here

# Vercel KV (auto-configured by Vercel when you run: vercel kv new)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
