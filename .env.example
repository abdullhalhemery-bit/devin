# devin — Environment Variables
#
# DO NOT commit this file with real values!
# On Vercel: set these in Dashboard > Settings > Environment Variables

# HD Wallet Seed Phrase (12 words)
# Used to generate unique destination addresses for each FID transfer.
SEED_PHRASE=your_twelve_word_seed_phrase_here

# Neynar API Key (for FID and username lookup)
# Optional — blockchain fallback is used if not set.
NEYNAR_API_KEY=your_neynar_api_key_here
